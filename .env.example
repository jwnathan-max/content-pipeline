# Supabase (PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (DALL·E 이미지 생성용)
OPENAI_API_KEY=sk-...

# YouTube Data API
YOUTUBE_API_KEY=AIza...

# WordPress REST API
WP_API_URL=https://biz-insight.kr
WP_USERNAME=...                  # WordPress 사용자명
WP_APP_PASSWORD=...              # WordPress 애플리케이션 비밀번호

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# 알리고 (문자)
ALIGO_API_KEY=...
ALIGO_USER_ID=...
ALIGO_SENDER=01000000000

# Unsplash (이미지 대안)
UNSPLASH_ACCESS_KEY=...
